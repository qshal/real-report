# Supabase Configuration
VITE_NEWS_API_KEY="your_news_api_key_here"
VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# TruthChain Blockchain Configuration
VITE_CONTRACT_ADDRESS="0x_your_deployed_contract_address"
VITE_BLOCKCHAIN_NETWORK="sepolia"
VITE_ETHEREUM_RPC_URL="https://mainnet.infura.io/v3/YOUR_PROJECT_ID"
VITE_SEPOLIA_RPC_URL="https://rpc.sepolia.org"
VITE_BLOCKCHAIN_API_URL="http://localhost:5000/api/blockchain"
VITE_PIPELINE_VERSION="4.0.0"

# Backend TruthChain Service Configuration
CONTRACT_ADDRESS="0x_your_deployed_contract_address"
BLOCKCHAIN_NETWORK="sepolia"
POLYGON_RPC_URL="https://polygon-rpc.com"
MUMBAI_RPC_URL="https://rpc-mumbai.maticvigil.com"
ETHEREUM_RPC_URL="https://mainnet.infura.io/v3/YOUR_PROJECT_ID"
SEPOLIA_RPC_URL="https://rpc.sepolia.org"
BLOCKCHAIN_PRIVATE_KEY="your_wallet_private_key_without_0x_prefix"
PIPELINE_VERSION="4.0.0"

# Hardhat Deployment Configuration
PRIVATE_KEY="your_wallet_private_key_without_0x_prefix"